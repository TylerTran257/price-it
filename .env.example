# Environment
ENVIRONMENT=development

# Geocoding (using Nominatim for free geocoding - no API key needed!)
GEOCODING_PROVIDER=nominatim

# Cache (in-memory for POC)
CACHE_TTL_SECONDS=86400

# MLS Settings (mock, ntreis, or corelogic)
# Using CoreLogic Trestle WebAPI - see docs/MLS_INTEGRATION.md
MLS_PROVIDER=corelogic
# CoreLogic Trestle API (RESO WebAPI/OData)
MLS_RESO_URL=https://api.cotality.com/trestle/odata
MLS_OAUTH_TOKEN_URL=https://api.cotality.com/trestle/oidc/connect/token
MLS_CLIENT_ID=your_consumer_key_here
MLS_CLIENT_SECRET=your_consumer_secret_here

# Pricing Engine
COMPS_RADIUS_MILES=1.0
SOLD_LOOKBACK_DAYS=180
PRICE_PERCENTILE_LOW=25
PRICE_PERCENTILE_HIGH=75
SQFT_TOLERANCE_PCT=20
BEDROOM_TOLERANCE=1
MIN_COMPS_REQUIRED=3

# Discord Bot (optional - for chatbot integration)
# DISCORD_TOKEN=your_discord_bot_token_here
